          "aspire": {
            "focusService": "admin",
            "tasks": {
              "local": "aspire:start",
              "saas": "aspire:full",
              "hybrid": "aspire:hybrid"
            }
          }
        }
      ]
    },
    {
      "id": "kombify-ai",
      "name": "kombify AI",
      "path": "kombify-AI",
      "aspireFocusService": "ai",
      "components": [
        {
          "id": "backend-portal",
          "packaging": "embedded",
