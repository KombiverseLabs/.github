          "modes": ["local", "saas", "hybrid"],
          "composeFile": "docker-compose.local.yml",
          "manualUrls": ["http://localhost:8090", "http://localhost:4292"],
          "healthUrls": ["http://localhost:8090/health"],
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-saas-like" }
          },
          "aspire": {
            "focusService": "ai",
            "tasks": {
