{
  "version": 1,
  "schema": "kombify-local-gates",
  "workspaceRoot": "..",
  "aspireAppHost": "kombify-Core/aspire/apphost.cs",
  "requiredMiseTasks": [
    "setup",
    "doctor",
    "build",
    "test",
    "check",
    "health",
    "preview:local",
    "preflight:quick",
    "preflight:release",
    "preflight:deploy",
    "aspire:start",
    "aspire:full"
  ],
  "optionalMiseTasks": [
    "aspire:saas",
    "aspire:selfhosted",
    "aspire:hybrid"
  ],
  "aspireProfiles": {
    "local": "local-minimal",
    "saas": "local-saas-like",
    "selfhosted": "local-minimal",
    "hybrid": "local-hybrid",
    "integration": "integration-ghcr"
  },
  "repos": [
    {
      "id": "kombify-blog",
      "name": "kombify Blog",
      "path": "kombify-Blog",
      "aspireFocusService": "blog",
      "components": [
        {
          "id": "site",
          "packaging": "standalone",
          "runtime": "docker-compose",
          "modes": ["local", "saas"],
          "composeFile": "docker-compose.yml",
          "manualUrls": ["http://localhost:5280"],
          "healthUrls": ["http://localhost:5280"],
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-saas-like" }
          },
          "aspire": {
            "focusService": "blog",
            "tasks": {
              "local": "aspire:start",
              "saas": "aspire:full"
            }
          }
        }
      ]
    },
    {
      "id": "kombify-cloud",
      "name": "kombify Cloud",
      "path": "kombify-Cloud",
      "aspireFocusService": "cloud",
      "components": [
        {
          "id": "portal",
          "packaging": "embedded",
          "runtime": "aspire",
          "modes": ["local", "saas", "hybrid", "integration"],
          "composeFile": "docker-compose.local.yml",
          "manualUrls": ["http://localhost:5290"],
          "healthUrls": ["http://localhost:5290/health"],
          "healthUrlsByMode": {
            "local": ["http://localhost:5290/health"],
            "saas": ["http://localhost:5173/health"],
            "hybrid": ["http://localhost:5290/health"],
            "integration": ["http://localhost:5290/health"]
          },
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-saas-like" }
          },
          "aspire": {
            "focusService": "cloud",
            "tasks": {
              "local": "aspire:start",
              "saas": "aspire:full",
              "hybrid": "aspire:hybrid"
            },
            "profiles": {
              "local": "local-minimal",
              "saas": "local-saas-like",
              "hybrid": "local-hybrid"
            }
          }
        }
      ]
    },
    {
      "id": "kombify-techstack",
      "name": "kombify Techstack",
      "path": "kombify-Techstack",
      "aspireFocusService": "stack",
      "components": [
        {
          "id": "api-ui",
          "packaging": "standalone",
          "runtime": "docker-compose",
          "modes": ["local", "selfhosted", "hybrid"],
          "composeFile": "docker-compose.yml",
          "manualUrls": ["http://localhost:5260", "http://localhost:5261"],
          "healthUrls": ["http://localhost:5260/api/v1/health", "http://localhost:5261"],
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-hybrid" }
          },
          "aspire": {
            "focusService": "stack",
            "tasks": {
              "local": "aspire:start",
              "selfhosted": "aspire:selfhosted",
              "hybrid": "aspire:hybrid"
            }
          }
        }
      ]
    },
    {
      "id": "kombify-db",
      "name": "kombify DB",
      "path": "kombify-DB",
      "aspireFocusService": "db",
      "components": [
        {
          "id": "postgres-schema",
          "packaging": "standalone",
          "runtime": "docker-compose",
          "modes": ["local"],
          "composeFile": "docker-compose.yml",
          "manualUrls": ["postgres://localhost:5432/kombify"],
          "healthUrls": [],
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-minimal" }
          },
          "aspire": {
            "focusService": "db"
          }
        }
      ]
    },
    {
      "id": "kombify-core",
      "name": "kombify Core",
      "path": "kombify-Core",
      "aspireFocusService": "core",
      "components": [
        {
          "id": "ui-lab",
          "packaging": "standalone",
          "runtime": "docker-compose",
          "modes": ["local"],
          "composeFile": "ui-lab/docker-compose.yml",
          "manualUrls": ["http://localhost:5293"],
          "healthUrls": ["http://localhost:5293/api/health"],
          "gates": {
            "quick": { "miseTask": "preflight:quick" },
            "standard": { "miseTask": "preflight:release" },
            "full": { "miseTask": "preflight:deploy", "aspireProfile": "local-minimal" }
          },
          "aspire": {
            "focusService": "core"
          }
        }
      ]
    },
    {
      "id": "kombify-administration",
